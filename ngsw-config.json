{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "dataGroups": [
    {
      "name": "api-no-cache",
      "urls": ["/api/v1/admin/**"],
      "cacheConfig": {
        "strategy": "networkOnly"
      }
    },
    {
      "name": "api-performance",
      "urls": ["/api/v1/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1h",
        "timeout": "10s"
      }
    }
  ],
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/index.html", "/favicon.ico", "/manifest.webmanifest", "/*.(js|css)"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/**(png|jpg|jpeg|gif|ico|svg|woff2|ttf|eot)"]
      }
    }
  ]
}
