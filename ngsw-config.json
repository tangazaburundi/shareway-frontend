{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(eot|svg|ttf|woff|woff2|otf)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-fresh",
      "urls": [
        "/api/v1/users/me",
        "/api/v1/trips/search*"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 10,
        "maxAge": "1h",
        "timeout": "5s"
      }
    },
    {
      "name": "api-cache",
      "urls": [
        "/api/v1/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "10m",
        "timeout": "10s"
      }
    }
  ],
  "navigationUrls": [
    "!/**"
  ]
}
